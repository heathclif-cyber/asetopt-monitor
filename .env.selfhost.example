# =============================================================================
# AsetOpt Monitor — environment self-host (Windows / Docker Desktop)
# Copy:  copy .env.selfhost.example .env.selfhost
# Jangan commit .env.selfhost (berisi password / kredensial Superman)
# =============================================================================

# --- PostgreSQL (service db) ---
POSTGRES_USER=asetopt
POSTGRES_PASSWORD=ganti_password_kuat
POSTGRES_DB=asetopt
POSTGRES_PORT=5432

# Port di host Windows (browser / firewall)
API_PORT=8000
WEB_PORT=3001

# --- Superman (API) ---
SUPERMAN_URL=https://superman.ptpn1.co.id/
SUPERMAN_USER=
SUPERMAN_PASSWORD=
# Atau base64 jika password berisi karakter aneh:
# SUPERMAN_PASSWORD_B64=

SUPERMAN_FLOW_ID=32
SUPERMAN_BAGIAN=223
SUPERMAN_GL_PENDAPATAN_ASET=41100030
SUPERMAN_GL_PPN=21060008
SUPERMAN_GL_PPH=11600000
SUPERMAN_PROFIT_CENTER=A0101
SUPERMAN_CASH_FLOW=1
SUPERMAN_HEADLESS=true

# Opsional WhatsApp (Fonnte)
# VITE_FONNTE_TOKEN=
