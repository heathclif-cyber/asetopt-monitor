# Kosongkan VITE_API_URL untuk local dev (proxy Vite → localhost:8000)
# Production frontend: kosongkan VITE_API_URL, set API_PROXY_URL di runtime
#   Railway: API_PROXY_URL=https://<service-api>.up.railway.app
#   Self-host Docker: lihat .env.selfhost.example + DEPLOY_SELFHOST.md
VITE_API_URL=

# Production frontend (server/index.js) — proxy /api ke service Python
# API_PROXY_URL=https://<service-api>.up.railway.app
# Self-host: API_PROXY_URL=http://127.0.0.1:8000  (atau http://api:8000 di Docker)
VITE_SUPABASE_ANON_KEY=railway-internal
VITE_FONNTE_TOKEN=your_fonnte_api_token
