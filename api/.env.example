# PostgreSQL — Railway
# Deploy (di Railway): pakai internal URL
#   postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
# Local dev: pakai PUBLIC URL dari Railway Dashboard → PostgreSQL → Connect → Public Network
#   postgresql://postgres:PASSWORD@xxx.proxy.rlwy.net:PORT/railway
DATABASE_URL=postgresql://postgres:PASSWORD@xxx.proxy.rlwy.net:PORT/railway

# Local file uploads
UPLOAD_DIR=./uploads

# Superman automation
SUPERMAN_URL=https://superman.ptpn1.co.id/
SUPERMAN_USER=
SUPERMAN_PASSWORD=
# SUPERMAN_PASSWORD_B64=

SUPERMAN_FLOW_ID=32
SUPERMAN_BAGIAN=223
SUPERMAN_GL_PENDAPATAN_ASET=41100030
SUPERMAN_GL_PPN=21060008
SUPERMAN_GL_PPH=11600000
SUPERMAN_PROFIT_CENTER=A0101
SUPERMAN_CASH_FLOW=1
SUPERMAN_STATE_PATH=./.superman_state.json
SUPERMAN_HEADLESS=true
# SUPERMAN_AUTO_LOGIN=true

# Setup Playwright (sekali, di mesin API):
#   cd api && pip install -r requirements.txt
#   python scripts/setup_playwright.py
# Login manual (simpan session, isi captcha di browser):
#   python scripts/superman_login.py --manual